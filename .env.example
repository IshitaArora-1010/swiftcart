# Copy this file to .env and fill in your values before running docker-compose.
# Never commit the real .env file — it is listed in .gitignore.

# PostgreSQL connection — the default below matches docker-compose.yml exactly
DATABASE_URL=postgresql://postgres:password@db:5432/order_processing

# Anthropic API key for AI chat support (get one at console.anthropic.com)
# The chat feature degrades gracefully if this is left blank
ANTHROPIC_API_KEY=your_anthropic_api_key_here
